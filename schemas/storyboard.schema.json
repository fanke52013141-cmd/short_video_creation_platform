{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storyboard",
  "type": "object",
  "required": ["shots"],
  "properties": {
    "shots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "shot_id",
          "scene_id",
          "duration_seconds",
          "framing",
          "camera_move",
          "action_desc",
          "characters_in_shot",
          "location"
        ],
        "properties": {
          "shot_id": { "type": "string", "pattern": "^S[0-9]{3}$" },
          "scene_id": { "type": "string" },
          "duration_seconds": { "type": ["integer", "number"] },
          "framing": { "type": "string" },
          "camera_move": { "type": "string" },
          "action_desc": { "type": "string" },
          "characters_in_shot": { "type": "array", "items": { "type": "string" } },
          "location": { "type": "string" },
          "quality_gate": { "type": ["object", "null"] }
        }
      }
    }
  }
}
