{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storyboard",
  "type": "object",
  "required": ["shots"],
  "properties": {
    "shots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "shot_id",
          "scene_id",
          "duration_seconds",
          "framing",
          "camera_move",
          "action_desc"
        ],
        "properties": {
          "shot_id": { "type": "string", "pattern": "^S[0-9]{3}$" },
          "scene_id": { "type": "string", "pattern": "^SC[0-9]{3}$" },
          "duration_seconds": { "type": ["integer", "number"], "exclusiveMinimum": 0, "maximum": 15 },
          "framing": { "type": "string" },
          "camera_move": { "type": "string" },
          "action_desc": { "type": "string" }
        }
      }
    }
  }
}
