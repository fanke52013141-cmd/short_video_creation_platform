{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Video Segment Plan",
  "type": "object",
  "required": ["segments"],
  "properties": {
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["video_id", "source_shots", "scene_id", "duration_seconds", "merge_strategy", "merge_reason", "frame_plan"],
        "properties": {
          "video_id": {"type": "string", "pattern": "^V[0-9]{3}$"},
          "source_shots": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^S[0-9]{3}$"}},
          "scene_id": {"type": "string", "pattern": "^SC[0-9]{3}$"},
          "duration_seconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 15},
          "merge_strategy": {"type": "string", "enum": ["single_shot", "continuous_action", "continuous_camera_move", "continuous_spatial_relation"]},
          "merge_reason": {"type": "string", "minLength": 1},
          "frame_plan": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["shot_id", "role"],
              "properties": {
                "shot_id": {"type": "string", "pattern": "^S[0-9]{3}$"},
                "role": {"type": "string", "enum": ["first_frame", "last_frame", "keyframe"]}
              }
            }
          }
        }
      }
    }
  }
}
