{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shot Video Prompt",
  "type": "object",
  "required": [
    "shot_id",
    "duration_seconds",
    "task_type",
    "storyboard_reference",
    "character_references",
    "audio_reference_decision",
    "env_reference_decision",
    "prop_policy",
    "prompt_cn",
    "self_check"
  ],
  "properties": {
    "shot_id": { "type": "string", "pattern": "^SHOT_[0-9]{3}$" },
    "duration_seconds": { "type": ["integer", "number"] },
    "task_type": {
      "type": "string",
      "enum": [
        "pipeline_shot_generation",
        "multimodal_reference",
        "video_edit",
        "video_extend",
        "combined_task"
      ]
    },
    "seedance_sentence_type": {
      "type": ["string", "null"],
      "enum": ["reference", "strict_edit", "extend_forward", "extend_backward", "pipeline", "combined", null]
    },
    "storyboard_reference": { "type": "string" },
    "character_references": { "type": "array", "items": { "type": "string" } },
    "external_references": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "asset_name": { "type": "string" },
          "asset_kind": {
            "type": ["string", "null"],
            "enum": ["image", "video", "audio", null]
          },
          "asset_role": { "type": ["string", "null"] },
          "locked_dimensions": {
            "type": ["array", "string", "null"],
            "items": { "type": "string" }
          },
          "subject_definitions": {
            "type": ["array", "string", "null"],
            "items": { "type": "string" }
          }
        }
      }
    },
    "image_reference_decision": { "type": ["object", "string", "null"] },
    "audio_reference_decision": { "type": ["object", "string"] },
    "env_reference_decision": { "type": ["object", "string"] },
    "prop_policy": { "type": "string" },
    "asset_declaration": { "type": ["array", "string", "null"] },
    "subject_definitions": { "type": ["array", "string", "null"] },
    "voice_and_dialogue_policy": { "type": ["object", "string", "null"] },
    "sound_symbol_policy": { "type": ["object", "string", "null"] },
    "text_generation_policy": { "type": ["object", "string", "null"] },
    "camera_movement_policy": { "type": ["object", "string", "null"] },
    "prompt_cn": { "type": "string" },
    "self_check": { "type": ["array", "object", "string"] }
  }
}
