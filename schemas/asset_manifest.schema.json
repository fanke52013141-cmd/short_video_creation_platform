{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Asset Manifest",
  "type": "object",
  "required": ["characters", "scenes", "props"],
  "properties": {
    "naming_policy": { "type": ["string", "null"] },
    "characters": { "$ref": "#/$defs/assets" },
    "scenes": { "$ref": "#/$defs/assets" },
    "props": { "$ref": "#/$defs/assets" }
  },
  "$defs": {
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "asset_name", "canonical_name", "asset_type", "generation_required", "approval_status"],
        "properties": {
          "asset_id": { "type": "string", "pattern": "^(character|scene|prop)\\.[a-z0-9-]+(\\.[a-z0-9-]+)?$" },
          "asset_name": { "type": "string" },
          "canonical_name": { "type": "string" },
          "variant_name": { "type": ["string", "null"] },
          "variant_reasons": {
            "type": ["array", "null"],
            "items": {"type": "string", "enum": ["base_identity", "age_change", "persistent_costume_change", "persistent_hair_change", "persistent_injury", "identity_transformation", "structural_change", "prop_state_change", "user_required"]}
          },
          "asset_type": { "type": "string", "enum": ["character", "scene", "prop"] },
          "naming_strategy": {
            "type": ["string", "null"],
            "enum": ["numbered_subject", "custom_concrete_name", "character_state_name", "simple_scene_number", "concrete_scene_name", "key_prop_name", null]
          },
          "seedance_label": { "type": ["string", "null"] },
          "definition_sentence": { "type": ["string", "null"] },
          "reference_bindings": {
            "type": ["array", "null"],
            "items": {
              "type": "object",
              "properties": {
                "source_id": { "type": "string" },
                "source_type": { "type": "string", "enum": ["image", "video", "generated_asset", "text_only"] },
                "role": { "type": "string" },
                "notes": { "type": ["string", "null"] }
              }
            }
          },
          "base_name": { "type": ["string", "null"] },
          "feature": { "type": ["string", "null"] },
          "state": { "type": ["string", "null"] },
          "angle_or_view": { "type": ["string", "null"] },
          "visual_anchors": { "type": ["array", "string", "null"], "items": { "type": "string" } },
          "generation_required": { "type": "boolean" },
          "reference_layout": { "type": ["string", "null"], "enum": ["character_identity_quad_v1", "scene_spatial_quad_v1", "prop_reference_quad_v1", "single_reference", null] },
          "canonical_path": { "type": ["string", "null"] },
          "source_path": { "type": ["string", "null"] },
          "content_hash": { "type": ["string", "null"] },
          "version": { "type": ["integer", "null"], "minimum": 1 },
          "approval_status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
          "output_prompt_path": { "type": ["string", "null"] },
          "prompt_scope": { "type": ["string", "null"] },
          "handling_policy": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
