{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Art Direction",
  "type": "object",
  "required": [
    "visual_principles",
    "color_rules",
    "lighting_rules",
    "material_rules",
    "cinematography_rules",
    "negative_style_rules",
    "compressed_prompt_style_block"
  ],
  "properties": {
    "art_direction_mode": {
      "type": "string",
      "enum": [
        "reference_image_first",
        "user_visual_direction_preservation",
        "open_art_direction"
      ]
    },
    "visual_input_type": {
      "type": "string",
      "enum": [
        "reference_image_provided",
        "explicit_visual_notes",
        "open_visual_direction",
        "conflicting_reference"
      ]
    },
    "reference_paths": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "reference_image_policy": {
      "type": ["object", "string", "null"]
    },
    "reference_image_analysis": {
      "type": ["object", "array", "string", "null"]
    },
    "style_expansion_policy": {
      "type": ["object", "string", "null"]
    },
    "user_visual_constraints": {
      "type": ["object", "array", "string", "null"]
    },
    "candidate_generation_mode": {
      "type": ["string", "null"],
      "enum": [
        "reference_based_variants",
        "open_style_candidates",
        null
      ]
    },
    "visual_principles": { "type": ["array", "object", "string"] },
    "color_rules": { "type": ["array", "object", "string"] },
    "lighting_rules": { "type": ["array", "object", "string"] },
    "material_rules": { "type": ["array", "object", "string"] },
    "cinematography_rules": { "type": ["array", "object", "string"] },
    "character_visual_rules": { "type": ["array", "object", "string", "null"] },
    "scene_visual_rules": { "type": ["array", "object", "string", "null"] },
    "negative_style_rules": { "type": ["array", "object", "string"] },
    "platform_adaptation": { "type": ["object", "string", "null"] },
    "compressed_prompt_style_block": { "type": "string" }
  }
}
