{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Story",
  "type": "object",
  "required": [
    "title_candidates",
    "logline",
    "duration_minutes",
    "genre",
    "theme_question",
    "characters",
    "locations",
    "beats",
    "visual_moments",
    "production_constraints"
  ],
  "properties": {
    "story_generation_mode": {
      "type": "string",
      "enum": [
        "complete_story_preservation",
        "draft_diagnosis_optimization",
        "exploration_question",
        "structure_building",
        "full_story_development"
      ]
    },
    "completeness_assessment": {
      "type": "string",
      "enum": [
        "complete_story",
        "partial_draft",
        "basic_direction",
        "vague_idea",
        "full_development_requested"
      ]
    },
    "preservation_policy": {
      "type": ["object", "string", "null"]
    },
    "preserved_elements": {
      "type": ["object", "array", "null"]
    },
    "optimized_elements": {
      "type": ["object", "array", "null"]
    },
    "status": {
      "type": "string",
      "enum": [
        "needs_user_answer",
        "draft_diagnosed",
        "story_structured",
        "story_optimized",
        "ready_for_art_direction"
      ]
    },
    "title_candidates": { "type": "array", "items": { "type": "string" } },
    "logline": { "type": "string" },
    "duration_minutes": { "type": ["number", "string"] },
    "genre": { "type": "string" },
    "theme_question": { "type": "string" },
    "characters": { "type": "array", "items": { "type": "object" } },
    "locations": { "type": "array", "items": { "type": "object" } },
    "beats": { "type": "array", "items": { "type": "object" } },
    "visual_moments": { "type": "array", "items": { "type": ["string", "object"] } },
    "dialogue_or_voiceover_intent": { "type": ["string", "array", "object", "null"] },
    "production_constraints": { "type": ["object", "array"] }
  }
}
