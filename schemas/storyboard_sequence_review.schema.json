{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Storyboard Sequence Review",
  "type": "object",
  "required": ["reviewer", "status", "concretization_check_passed", "checked_shots", "adjacent_checks", "issues"],
  "properties": {
    "reviewer": { "type": "string", "enum": ["ai"] },
    "status": { "type": "string", "enum": ["pass", "revise_required"] },
    "max_shot_duration_seconds": { "type": ["integer", "number", "null"] },
    "duration_check_passed": { "type": ["boolean", "null"] },
    "shot_boundary_check_passed": { "type": ["boolean", "null"] },
    "concretization_check_passed": { "type": "boolean" },
    "key_turning_point_visual_evidence_check_passed": { "type": ["boolean", "null"] },
    "storytelling_quality_check_passed": { "type": ["boolean", "null"] },
    "checked_shots": { "type": ["array", "integer"] },
    "checked_windows_1shot": { "type": ["array", "integer"] },
    "checked_windows_2shot": { "type": ["array", "integer"] },
    "checked_windows_3shot": { "type": ["array", "integer"] },
    "adjacent_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["shot_ids", "shot_boundary_passed", "continuity_passed", "suggested_generation", "notes"],
        "properties": {
          "shot_ids": { "type": "array", "items": { "type": "string" } },
          "shot_boundary_passed": { "type": "boolean" },
          "continuity_passed": { "type": "boolean" },
          "suggested_generation": {
            "type": "string",
            "enum": ["independent_clip", "merge_with_previous", "previous_last_frame", "video_extend"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "abstract_prompt_issues": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "properties": {
          "shot_id": { "type": ["string", "null"] },
          "abstract_terms": { "type": ["array", "string", "null"], "items": { "type": "string" } },
          "missing_evidence_type": { "type": ["array", "string", "null"], "items": { "type": "string" } },
          "description": { "type": ["string", "null"] }
        }
      }
    },
    "p0_count": { "type": ["integer", "null"] },
    "p1_count": { "type": ["integer", "null"] },
    "p2_count": { "type": ["integer", "null"] },
    "p1_resolution_status": { "type": ["string", "null"] },
    "user_acceptance_required": { "type": ["boolean", "null"] },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description"],
        "properties": {
          "id": { "type": ["string", "null"] },
          "severity": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "category": {
            "type": ["string", "null"],
            "enum": [
              "duration",
              "shot_boundary",
              "concretization",
              "storytelling",
              "space",
              "prop",
              "character",
              "time",
              "sound",
              "motif",
              "style",
              null
            ]
          },
          "shot_ids": { "type": ["array", "null"], "items": { "type": "string" } },
          "description": { "type": "string" },
          "fix_suggestion": { "type": ["string", "null"] },
          "fix_applied": { "type": ["boolean", "null"] },
          "accepted_by_user": { "type": ["boolean", "null"] },
          "resolution_status": { "type": ["string", "null"] }
        }
      }
    }
  }
}
