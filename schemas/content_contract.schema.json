{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Advertising Content Contract",
  "type": "object",
  "required": ["schema_version", "vertical", "audience", "primary_message", "product", "claims", "cta", "production"],
  "properties": {
    "schema_version": {"type": "string"},
    "vertical": {"const": "advertising"},
    "audience": {"type": "object", "required": ["primary"], "properties": {"primary": {"type": "string"}, "problem_or_desire": {"type": ["string", "null"]}}},
    "primary_message": {"type": "string", "minLength": 1},
    "product": {"type": "object", "required": ["name"], "properties": {"name": {"type": "string"}, "mechanism": {"type": ["string", "null"]}, "offer": {"type": ["string", "null"]}}},
    "claims": {"type": "array", "items": {"type": "object", "required": ["text", "verification_status"], "properties": {"text": {"type": "string"}, "evidence": {"type": ["string", "null"]}, "verification_status": {"enum": ["verified", "unverified", "not_applicable"]}}}},
    "cta": {"type": "string"},
    "production": {"type": "object", "required": ["duration_seconds", "aspect_ratio", "channel"], "properties": {"duration_seconds": {"type": "number", "exclusiveMinimum": 0}, "aspect_ratio": {"type": "string"}, "channel": {"type": "string"}, "hook_deadline_seconds": {"type": "number", "minimum": 0}}},
    "brand_constraints": {"type": "array", "items": {"type": "string"}},
    "mandatory_disclaimer": {"type": ["string", "null"]}
  }
}

